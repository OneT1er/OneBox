<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Opt WPF (.NET Framework 4.7+ runtime) into per-monitor DPI rendering so the
         manifest's PerMonitorV2 declaration actually yields sharp text on mixed-DPI
         multi-monitor setups. Ignored (harmlessly) on older runtimes. -->
    <AppContextSwitchOverrides value="Switch.System.Windows.DoNotUsePresentationDpiCapabilityTier2=false" />
  </runtime>
</configuration>
